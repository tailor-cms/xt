{
  "name": "@tailor-cms/cek-e2e",
  "description": "Content element E2E testing utilities",
  "author": "Studion <info@gostudion.com>",
  "version": "2.0.0-beta.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "nuke": "pnpm dlx del-cli dist node_modules",
    "nuke:dist": "pnpm dlx del-cli dist",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@tailor-cms/eslint-config": "workspace:^",
    "@types/node": "^24.12.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "tsdown": {
    "target": "node22",
    "format": ["cjs", "esm"]
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@tailor-cms/cek-common",
  "description": "Content element kit shared util library",
  "author": "Studion <info@gostudion.com>",
  "version": "2.0.0-beta.4",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "nuke": "pnpm dlx del-cli dist node_modules",
    "nuke:dist": "pnpm dlx del-cli dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@lukeed/uuid": "^2.0.1",
    "ky": "^2.0.0",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@tailor-cms/eslint-config": "workspace:^",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.12.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "tsdown": {
    "target": "node22",
    "format": [
      "cjs",
      "esm"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@tailor-cms/cek-e2e",
  "description": "Content element E2E testing utilities",
  "author": "Studion <info@gostudion.com>",
  "version": "2.0.0-beta.14",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "nuke": "pnpm dlx del-cli dist node_modules",
    "nuke:dist": "pnpm dlx del-cli dist",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@tailor-cms/eslint-config": "workspace:^",
    "@types/node": "^24.12.2",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "tsdown": {
    "target": "node24"
  },
  "publishConfig": {
    "access": "public"
  }
}

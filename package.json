{
  "name": "@tailor-cms/xt",
  "version": "1.0.0",
  "description": "Tailor extensions kit",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "start:example": "pnpm -r --filter=./example run dev",
    "lint": "pnpm -r --filter=!./example/packages/** run lint",
    "build": "pnpm -r --filter=!./example/packages/** run build",
    "nuke:dist": "pnpm -r --filter=!./example/packages/** run nuke:dist",
    "nuke": "pnpm -r --filter=!./example/packages/** run nuke && pnpm dlx del-cli node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1"
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22"
  }
}
